# Phase 7 — Constrained Model-Assisted Answer Rendering (LOCAL DEVELOPMENT ONLY)
#
# The live renderer is DISABLED by default and is disabled entirely in
# production. It only organizes pre-approved answer elements; it never retrieves,
# judges authority, classifies risk, generates citations, or writes trusted
# factual sentences. Copy this file to `.env.local` (which is gitignored) to
# enable it locally.

# Turn the live renderer on/off (must be "true" to enable).
ANSWER_RENDERER_ENABLED=false

# Which provider to use: "none" or "openai".
ANSWER_RENDERER_PROVIDER=none

# OpenAI credentials (server-only; never exposed to the browser).
OPENAI_API_KEY=

# You MUST choose a model explicitly — there is no default.
OPENAI_MODEL=
